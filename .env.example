# ── Backend selection ──
# postgres | parquet
DATA_BACKEND=parquet

# ── PostgreSQL connection ──
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
ALTAS_DB=
SERIES_DB=

# ── Parquet storage ──
# Directory containing parquet files (required when DATA_BACKEND=parquet)
PARQUET_DATA_DIR=

# Path where raw water-balance datasets are stored / downloaded
DATA_PATH=

# ── Config ──
# Directory for YAML config files (default: ./config)
LAKE_CONFIG_DIR=./config

# ── Logging ──
LOG_LEVEL=INFO

# ── Water-balance dataset downloads ──
# Optional. Required only for authenticated GRACE / GLEAM downloads.
# EARTHDATA_USERNAME=
# EARTHDATA_PASSWORD=
# GRACE_URL=
# GLEAM_SFTP_HOST=hydras.ugent.be
# GLEAM_SFTP_PORT=2225
# GLEAM_SFTP_USERNAME=
# GLEAM_SFTP_PASSWORD=
# GLEAM_REMOTE_DIR=
# GLEAM_REMOTE_FILES=

# ── PostGIS lake geometries (deprecated; now in config/tables.yaml) ──
# Legacy overrides — prefer config/tables.yaml atlas_db.geometry section.
# LAKE_GEOMETRY_TABLE=
# LAKE_GEOMETRY_ID_COLUMN=
# LAKE_GEOMETRY_GEOM_COLUMN=
# LAKE_GEOMETRY_SIMPLIFY_METERS=
