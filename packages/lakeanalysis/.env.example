ALTAS_DB=
SERIES_DB=
DB_USER=
DB_PASSWORD=
DB_HOST=(optional, default is localhost)
DB_PORT=(optional, default is 5432)
LOG_LEVEL=(optional, default is INFO)

# Path where raw water-balance datasets are stored / downloaded
DATA_PATH=

# --- Water-balance dataset downloads ---
# Optional. Fill these values in packages/lakeanalysis/.env when you want the
# authenticated downloader to pull GRACE / GLEAM raw files.
# EARTHDATA_USERNAME=
# EARTHDATA_PASSWORD=
# Optional override. Defaults to the current JPL Mascon granule URL.
# GRACE_URL=
# GLEAM_SFTP_HOST=hydras.ugent.be
# GLEAM_SFTP_PORT=2225
# GLEAM_SFTP_USERNAME=
# GLEAM_SFTP_PASSWORD=
# Example: /data/v4.2a/monthly
# GLEAM_REMOTE_DIR=
# Comma-separated filenames, e.g. E_1980-2024_GLEAM_v4.2a_MO.nc
# GLEAM_REMOTE_FILES=

# --- PostGIS lake geometries (for fetch_lake_geometry_wkt_by_ids on ALTAS_DB) ---
# Optional. If unset, defaults to LakeATLAS_v10_pol (table name only).
# Relation as schema.table or table, e.g. hydroatlas.LakeATLAS_v10_pol
# LAKE_GEOMETRY_TABLE=
# LAKE_GEOMETRY_ID_COLUMN=hylak_id
# LAKE_GEOMETRY_GEOM_COLUMN=geom
# Optional positive float: simplify outlines in Web Mercator (m) before WKT; output WGS84
# LAKE_GEOMETRY_SIMPLIFY_METERS=
