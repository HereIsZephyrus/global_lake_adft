ALTAS_DB=
SERIES_DB=
DB_USER=
DB_PASSWORD=
DB_HOST=(optional, default is localhost)
DB_PORT=(optional, default is 5432)
LOG_LEVEL=(optional, default is INFO)

# --- PostGIS lake geometries (for fetch_lake_geometry_wkt_by_ids on ALTAS_DB) ---
# Optional. If unset, defaults to LakeATLAS_v10_pol (table name only).
# Relation as schema.table or table, e.g. hydroatlas.LakeATLAS_v10_pol
# LAKE_GEOMETRY_TABLE=
# LAKE_GEOMETRY_ID_COLUMN=hylak_id
# LAKE_GEOMETRY_GEOM_COLUMN=geom
# Optional positive float: simplify outlines in Web Mercator (m) before WKT; output WGS84
# LAKE_GEOMETRY_SIMPLIFY_METERS=
