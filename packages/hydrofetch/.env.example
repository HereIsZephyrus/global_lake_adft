# Hydrofetch environment configuration
# Copy this file to .env and fill in the values.

# ---- Google Earth Engine -----------------------------------------------
# Cloud project ID registered for Earth Engine access.
HYDROFETCH_GEE_PROJECT=your-gee-project-id

# ---- Google Drive OAuth ------------------------------------------------
# OAuth2 client-secrets JSON downloaded from Google Cloud Console
# (Application type: Desktop app).
HYDROFETCH_CREDENTIALS_FILE=~/.hydrofetch/credentials.json

# Where to cache the OAuth token (auto-created after first browser consent).
# HYDROFETCH_TOKEN_FILE=~/.hydrofetch/token.json

# ---- Drive export destination ------------------------------------------
# Name of the Google Drive folder where GEE writes exported TIF files.
# Leave blank to use the GEE default (root of My Drive).
HYDROFETCH_DRIVE_FOLDER_NAME=hydrofetch_exports

# ---- Local storage directories -----------------------------------------
# Serialised job records (one JSON file per job).
# HYDROFETCH_JOB_DIR=./hydrofetch_jobs

# Downloaded raw GeoTIFF files (one .tif per job).
# HYDROFETCH_RAW_DIR=./hydrofetch_raw

# Sampled lake-forcing Parquet files (one per job).
# HYDROFETCH_SAMPLE_DIR=./hydrofetch_sample

# ---- Runner settings ---------------------------------------------------
# Maximum number of concurrently active GEE export tasks.
# HYDROFETCH_MAX_CONCURRENT=5

# Seconds between status-check polls.
# HYDROFETCH_POLL_INTERVAL=15

# ---- PostgreSQL sink / smoke fixtures (optional) -----------------------
# HYDROFETCH_DB_* are used by hydrofetch writes and also act as SERIES_DB for
# the smoke fixture generator. ALTAS_DB is only needed when loading real lake
# geometries from LakeATLAS_v10_pol for smoke tests.
ALTAS_DB=your_atlas_database
HYDROFETCH_DB=your_database
HYDROFETCH_DB_USER=your_user
HYDROFETCH_DB_PASSWORD=your_password
# HYDROFETCH_DB_HOST=localhost
# HYDROFETCH_DB_PORT=5432
